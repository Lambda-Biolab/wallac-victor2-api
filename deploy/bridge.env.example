# Wallac Bridge environment file.
# Copy to /etc/wallac-bridge/bridge.env and fill in real values.
# DO NOT commit this file with real secrets.

# eLabFTW API (dedicated bridge key, NOT a human admin key)
WALLAC_ELABFTW_URL=https://localhost:3148
WALLAC_ELABFTW_API_KEY=
WALLAC_ELABFTW_CATEGORY=9

# vm-agent REST API (Windows 7 VM on libvirt NAT)
WALLAC_VM_AGENT_URL=http://192.168.122.203:8420
WALLAC_VM_AGENT_TOKEN=

# Dashboard (optional token for auth; empty = open on LAN)
WALLAC_DASHBOARD_TOKEN=
WALLAC_DASHBOARD_HOST=0.0.0.0
WALLAC_DASHBOARD_PORT=8421

# Bridge identity
WALLAC_BRIDGE_IDENTITY=wallac-bridge
WALLAC_DEVICE_IDENTITY=victor2-1420

# Result spool directory
WALLAC_SPOOL_DIR=/var/lib/wallac-bridge/spool

# Poll interval (seconds)
WALLAC_POLL_INTERVAL=5

# Generated-protocol authoring (DISABLED by default)
# Enable only after hardware e2e validation (Stage 7).
#WALLAC_ENABLE_PROTOCOL_AUTHORING=true
